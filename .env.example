# ─────────────────────────────────────────────────────────────
# SCFMS — docker-compose host-port overrides
# Copy to .env (repo root, alongside docker-compose.yml) if you need to
# change any of these. NEVER commit .env. Values here only affect the
# HOST-side port bindings; container-internal ports are unchanged.
#
# Defaults were chosen outside the common range (5432/6379/9000/8000)
# so SCFMS can run alongside other projects on the same host without a
# port collision. Override only the ones that actually clash for you.
# ─────────────────────────────────────────────────────────────

SCFMS_DB_PORT=15432
SCFMS_REDIS_PORT=16379
SCFMS_MINIO_PORT=19000
SCFMS_MINIO_CONSOLE_PORT=19001
SCFMS_BACKEND_PORT=18000
