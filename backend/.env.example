# ─────────────────────────────────────────────────────────────
# SCFMS Backend — environment configuration
# Copy to .env and fill real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# App
APP_NAME=SCFMS
ENVIRONMENT=development           # development | staging | production
DEBUG=true
# Override this if a shared reverse proxy needs a project-specific path
# (e.g. /scfms/api/v1) to avoid colliding with another project's routes.
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000"]
# CORS is enforced by browsers, not native mobile HTTP clients — the Flutter
# app's Dio requests are not subject to this list regardless of environment.
# Only add entries here for a browser-based client (e.g. a future Flutter
# Web build, or an admin panel), e.g. "https://admin.example.com".

# Host-side ports (docker-compose db/redis/minio/backend bindings) are
# configured separately in the repo-root .env.example — see SCFMS_*_PORT.

# Security — GENERATE REAL SECRETS FOR PRODUCTION:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (PostgreSQL + PostGIS)
# Preferred: a single DATABASE_URL. Percent-encode special characters in the
# password (e.g. "@" -> "%40"). The app uses sync SQLAlchemy (psycopg3), so the
# driver must be postgresql+psycopg (not asyncpg).
#   Remote server:  postgresql+psycopg://scfms_user:SCFMS%40123@<db-host>:5432/SCFMS
#   Same host as backend (more secure, no network exposure):
#                   postgresql+psycopg://scfms_user:SCFMS%40123@localhost:5432/SCFMS
DATABASE_URL=postgresql+psycopg://scfms_user:CHANGE_ME@localhost:5432/SCFMS

# Fallback (used only if DATABASE_URL is unset) — also what docker-compose's
# bundled db service is provisioned with.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=scfms
POSTGRES_PASSWORD=scfms_dev_password
POSTGRES_DB=scfms

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Object storage (MinIO / S3-compatible)
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=scfms_minio
S3_SECRET_KEY=scfms_minio_password
S3_BUCKET=scfms-media
S3_REGION=us-east-1

# Login protection
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Geofence defaults (company-overridable later)
DEFAULT_NEAR_DISTANCE_METERS=300
